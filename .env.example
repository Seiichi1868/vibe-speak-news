# OpenAI API キー（https://platform.openai.com/api-keys で取得）
# または管理画面 /admin/ の「OpenAI API キー」欄から保存できます
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FLASK_SECRET_KEY=change-me-in-production

# Render 等のクラウド環境で YouTube 文字起こしを取得する場合（Webshare Residential プラン）
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
# または任意の HTTP プロキシ URL
# YOUTUBE_PROXY_URL=http://user:pass@host:port
